APP_NAME=PhishPhage AI API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
ML_REGISTRY_PATH=services/ml/models/registry.json
ML_MODEL_ID=phase-c-logistic-regression-v1
